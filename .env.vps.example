# Example .env when running the app with MongoDB on your VPS
# Copy to .env and fill in your values.

PORT=3000
TARGET_URLS=https://webhook.site/your-unique-id/
ADMIN_PASSWORD=changeme
ADMIN_AUTH_REQUIRED=true
LOG_LEVEL=info

# MongoDB on VPS (required for persistence)
# Same server: use localhost. Different server: use VPS IP or hostname.
MONGODB_URI=mongodb://webhookapp:YOUR_APP_USER_PASSWORD@localhost:27017/webhookforwarder
# MONGODB_DB_NAME=webhookforwarder

REQUEST_TIMEOUT_MS=10000
RETRY_CONFIG={"maxAttempts":3,"delays":[1000,3000,9000]}
MAX_STORED_WEBHOOKS=2000
MAX_DLQ_ENTRIES=500
