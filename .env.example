# ──────────────────────────────────────────────────────────────────
#  Webhook Forwarder — Environment Variables
# ──────────────────────────────────────────────────────────────────

# HTTP port the server listens on (default: 3000)
PORT=3004

# Path to accept incoming webhooks on (default: /webhook)
WEBHOOK_PATH=/webhook

# Comma-separated list of target URLs (up to 5 or more)
TARGET_URLS=https://hooks.slack.com/services/XXX/YYY/ZZZ,https://api.example.com/webhook,https://notify.service.io/hook,https://integrations.other.com/api/events,https://fifth-service.io/ingest

# Per-target custom headers as a JSON object.
# Keys can be the target URL or "target-N" (1-indexed).
# Example: {"target-1":{"X-Slack-Token":"abc"},"target-2":{"Authorization":"Bearer xyz"}}
TARGET_HEADERS={}

# Request timeout per target in milliseconds (default: 10000)
REQUEST_TIMEOUT_MS=10000

# Retry configuration as JSON
# delays are in milliseconds; indexes correspond to attempt 0, 1, 2, ...
RETRY_CONFIG={"maxAttempts":3,"delays":[1000,3000,9000]}

# ── Signature Verification ───────────────────────────────────────

# Set to "true" to enable HMAC signature verification on incoming webhooks
SIGNATURE_VERIFY=false

# The shared secret used to compute and verify HMAC signatures
SIGNATURE_SECRET=your-webhook-secret

# The request header that contains the signature (GitHub uses x-hub-signature-256)
SIGNATURE_HEADER=x-hub-signature-256

# The HMAC algorithm (sha256 or sha1)
SIGNATURE_ALGORITHM=sha256

# ── Admin Dashboard ──────────────────────────────────────────────

# Username and password for the /admin/* routes (Basic Auth)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# Set to "false" to disable admin auth (not recommended in production)
ADMIN_AUTH_REQUIRED=true

# ── Storage ──────────────────────────────────────────────────────

# Maximum number of recent webhooks to keep in memory for replay
MAX_STORED_WEBHOOKS=200

# Maximum number of dead-letter queue entries to retain
MAX_DLQ_ENTRIES=500

# ── Logging ──────────────────────────────────────────────────────

# Log level: error | warn | info | http | verbose | debug | silly
LOG_LEVEL=info
